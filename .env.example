# forge environment template — copy to `.env` and fill in.
# Loaded by your shell (or via `set -a && source .env`); forge does not
# auto-load .env files.

# Anthropic API key for the Claude Agent SDK.
# Required for the live cycle (PM, dev-loop, reviewer, reflector all call
# the SDK). Claude Code installations may have alternative credentials at
# ~/.claude/.credentials.json — those work too, but production deployments
# should set ANTHROPIC_API_KEY explicitly.
ANTHROPIC_API_KEY=

# Optional: where managed projects live. Defaults to `./projects` relative to
# the forge cwd. Setting this overrides the default for `forge serve` runs.
# Same as forge.config.json's `projectsDir` — env wins if both are set.
# FORGE_PROJECTS_DIR=

# Optional: GitHub token for `gh` CLI calls (PR create + merge). Most users
# rely on `gh auth login` rather than this; export only if you need a fixed
# token (e.g. CI).
# GH_TOKEN=
