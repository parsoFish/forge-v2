Rel(Forgev2.OrchestratorEngine.CycleRunnerspine, Forgev2.OrchestratorEngine.ClosurePhase, "4. confirm merge + align", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.CycleRunnerspine, Forgev2.OrchestratorEngine.ReflectionPhase, "5. reflect (only if merged)", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.CycleRunnerspine, Forgev2.OrchestratorEngine.EventLogger, "Emits start/end + phase events to", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.CycleRunnerspine, Forgev2.OrchestratorEngine.FailureClassifier, "Classifies failures + writes the report via", $techn="", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml