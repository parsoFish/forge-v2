@startuml
title <size:24>Component View: Forge v2 - Orchestrator Engine</size>\n<size:24>Inside the orchestrator engine: the scheduler tier, the cycle spine + five phases, the Ralph runtime, and the shared machinery (queue, worktree, PR adapter, verdict, logging, classification).</size>

set separator none
left to right direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

Person(Operator, "Operator", $descr="The single human running forge across side projects. Touches the system at exactly three points, all on the forge UI (ADR 023): architect (idea -> initiative), review (approve the cycle), reflection (feedback).", $tags="", $link="")

System(ClaudeAgentSDK, "Claude Agent SDK", $descr="Anthropic's agent runtime + harness (model calls, tool use, prompt caching). Every forge agent runs here; forge hosts no model runtime, vector DB, or harness of its own.", $tags="", $link="")
System(GitHub, "GitHub", $descr="Hosts the managed-project repos. The PR is the operator's sole review + merge surface; merge state is the single terminal signal.", $tags="", $link="")
System(ManagedProjectRepo, "Managed Project Repo", $descr="A side-project git repo forge develops (trafficGame, terraform-provider-betterado, claude-harness...). Has its own quality gate and its own Brain 3. Worktrees branch from it.", $tags="", $link="")

System_Boundary("Forgev2_boundary", "Forge v2", $tags="") {
  Container_Boundary("Forgev2.OrchestratorEngine_boundary", "Orchestrator Engine", $tags="") {
    Component(Forgev2.OrchestratorEngine.SchedulerDispatch, "Scheduler Dispatch", $techn="scheduler-dispatch.ts", $descr="Routes a finished cycle's terminal status: done / failed / bounded auto-retry back to pending.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.DaemonControl, "Daemon Control", $techn="daemon.ts", $descr="Detached `forge serve` process state: pid, pause/resume flag, serve.log.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.CycleRunnerspine, "Cycle Runner (spine)", $techn="cycle.ts", $descr="Thin orchestration: threads phase outputs into the next phase, emits start/end events, classifies failures, snapshots artifacts. Resumable from the unifier (ADR 019).", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.PMPhase, "PM Phase", $techn="phases/project-manager.ts", $descr="Phase 1: invoke project-manager to decompose the initiative into atomic, dependency-ordered work items.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.DevLoopPhase, "Dev-Loop Phase", $techn="phases/developer-loop.ts", $descr="Phase 2: walk the WI DAG topologically, run a Ralph loop per work item, then the unifier (final Ralph) for cross-WI proof + demo + PR body.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.ReviewPhase, "Review Phase", $techn="phases/reviewer.ts", $descr="Phase 3: open the demo-embedded PR (thin, non-LLM); the PR is the operator's surface. Never merges.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.ClosurePhase, "Closure Phase", $techn="phases/closure.ts", $descr="Phase 4: the single terminal-move authority. Confirms the merge (gh pr view), aligns local->remote, moves the manifest to done/.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.ReflectionPhase, "Reflection Phase", $techn="phases/reflector.ts", $descr="Phase 5 (post-merge only): one-shot reflector that digests the event log and writes brain themes.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.RalphLoopRuntime, "Ralph Loop Runtime", $techn="loops/ralph/", $descr="Swappable agentic loop: re-read PROMPT/AGENT/fix_plan -> SDK query() -> commit -> check stop conditions (gate pass | iteration/cost budget). loops/_adapters is the placeholder for alternatives.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.InvocationContracts, "Invocation Contracts", $techn="*-invocation.ts", $descr="Single source of truth for each phase's system+user prompt, model, and allowed/disallowed tools.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.QueueStateMachine, "Queue State Machine", $techn="queue.ts / manifest.ts / work-item.ts", $descr="Atomic manifest transitions via rename(); manifest + work-item parse/validate/topo-sort.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.WorktreeManager, "Worktree Manager", $techn="worktree.ts", $descr="Thin wrapper over git worktree add/remove/prune; self-heals stale registry state.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.PRGitAdapter, "PR / Git Adapter", $techn="pr.ts (+ gh-shim.ts)", $descr="The only place forge shells git push / gh pr; enforces the local<->remote sync invariant; shims gh locally for no-origin projects.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.VerdictParser, "Verdict Parser", $techn="file-verdict.ts", $descr="Resolves the operator's review verdict from the verdict file the UI bridge writes (ADR 023 — the PR-comment provider + getVerdict seam were retired).", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.EventLogger, "Event Logger", $techn="logging.ts / tool-event-emit.ts", $descr="Append-only JSONL event log + tool-use telemetry. The single source of truth for a cycle.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.FailureClassifier, "Failure Classifier", $techn="failure-classifier.ts / cycle-report.ts", $descr="Reads the event log post-mortem; infers failure mode + recoverability; writes the human-facing REPORT.md.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.Notifier, "Notifier", $techn="notify.ts", $descr="Best-effort desktop + webhook notifications on terminal events.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.ArchitectRunnerinUI, "Architect Runner (in-UI)", $techn="architect-runner.ts", $descr="Turn-based, file-checkpointed architect driven from the UI bridge (ADR 020); advances one step per call via the LLM council.", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.Config, "Config", $techn="config.ts / project-config.ts", $descr="Per-machine forge.config.json + per-project .forge/project.json (quality gate, demo shape, heartbeat).", $tags="", $link="")
    Component(Forgev2.OrchestratorEngine.Scheduler, "Scheduler", $techn="scheduler.ts", $descr="~150-line forever loop: claims pending initiatives, spawns each in a worktree, heartbeats, recovers orphans, notifies.", $tags="", $link="")
  }

  Container(Forgev2.PhaseBrainSkills, "Phase & Brain Skills", $techn="Claude Code skills", $descr="The Claude Code skill catalog - forge's agent surface. Each skill is a system prompt + tool policy the engine loads into an SDK query(). Brain skills are the brain's read/write API.", $tags="", $link="")
  Container(Forgev2.CLIUtilities, "CLI Utilities", $techn="TypeScript (bin/forge.mjs)", $descr="forge subcommands (serve / watch / status / metrics / brain / requeue). The human moments are NOT here — they run on the UI (ADR 023).", $tags="", $link="")
  ContainerQueue(Forgev2.UIBridge, "UI Bridge", $techn="TypeScript (ws)", $descr="WebSocket + HTTP server (:4123). Tails the event log and scans the queue, streams snapshots + events to the browser, and accepts verdict/feedback files. Stateless: re-derives everything from the stores.", $tags="", $link="")
  Container(Forgev2.Monitor, "Monitor", $techn="Shell / tmux", $descr="tmux 3-pane layout (serve stdout / live event tail / forge status --watch) plus an Obsidian vault launcher.", $tags="", $link="")
  ContainerDb(Forgev2.InitiativeQueue, "Initiative Queue", $techn="Filesystem (_queue/)", $descr="Filesystem state machine of initiative manifests: pending -> in-flight -> ready-for-review -> done | failed. Atomic rename transitions; heartbeat files enable crash recovery. done/ implies MERGED.", $tags="", $link="")
  ContainerDb(Forgev2.EventLogArtifacts, "Event Log + Artifacts", $techn="Filesystem (_logs/)", $descr="Append-only per-cycle JSONL event log plus snapshotted work-items / demo / REPORT.md. The replayable source of truth for reflection, the UI, and metrics.", $tags="", $link="")
}

Rel(Forgev2.OrchestratorEngine.CycleRunnerspine, Forgev2.OrchestratorEngine.Config, "Reads forge.config / project.json via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.PMPhase, Forgev2.OrchestratorEngine.InvocationContracts, "Builds the PM prompt via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.PMPhase, Forgev2.PhaseBrainSkills, "Invokes (one-shot) via SDK", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.DevLoopPhase, Forgev2.OrchestratorEngine.InvocationContracts, "Builds the dev/unifier prompts via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.DevLoopPhase, Forgev2.OrchestratorEngine.RalphLoopRuntime, "Drives per-WI loops + the unifier via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.RalphLoopRuntime, Forgev2.PhaseBrainSkills, "Runs each work-item iteration", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.RalphLoopRuntime, ClaudeAgentSDK, "Calls query() each iteration (loads the dev/unifier skill)", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.RalphLoopRuntime, ManagedProjectRepo, "Commits worktree changes + runs the project quality gate", $techn="git / shell", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.RalphLoopRuntime, Forgev2.OrchestratorEngine.EventLogger, "Emits per-iteration cost + tool events to", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ReviewPhase, Forgev2.OrchestratorEngine.PRGitAdapter, "Opens the demo-embedded PR via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ReviewPhase, Forgev2.OrchestratorEngine.VerdictParser, "Reads the operator verdict via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ClosurePhase, Forgev2.OrchestratorEngine.PRGitAdapter, "Confirms merge + aligns local->remote via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ClosurePhase, Forgev2.InitiativeQueue, "Moves the manifest to done / ready-for-review", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ReflectionPhase, Forgev2.OrchestratorEngine.InvocationContracts, "Builds the reflector prompt via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ReflectionPhase, Forgev2.PhaseBrainSkills, "Invokes (one-shot, post-merge) via SDK", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ArchitectRunnerinUI, Forgev2.PhaseBrainSkills, "Advances the council one step via SDK", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.ArchitectRunnerinUI, Forgev2.InitiativeQueue, "Writes the draft initiative + PLAN to the session", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.PRGitAdapter, GitHub, "gh pr create / view; git push / fetch / ff", $techn="gh / git", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.PRGitAdapter, ManagedProjectRepo, "Pushes the initiative branch to", $techn="git", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.VerdictParser, Forgev2.InitiativeQueue, "Reads the UI-bridge-written verdict file in", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.EventLogger, Forgev2.EventLogArtifacts, "Appends JSONL + snapshots to", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.FailureClassifier, Forgev2.EventLogArtifacts, "Reads the event log; writes REPORT.md to", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Notifier, Operator, "Notifies (desktop / webhook)", $techn="", $tags="", $link="")
Rel(Forgev2.PhaseBrainSkills, ClaudeAgentSDK, "Executes on", $techn="", $tags="", $link="")
Rel(Forgev2.PhaseBrainSkills, Forgev2.EventLogArtifacts, "Digests the event log in", $techn="", $tags="", $link="")
Rel(Forgev2.PhaseBrainSkills, ManagedProjectRepo, "Writes the demo bundle + PR description to the worktree", $techn="", $tags="", $link="")
Rel(ManagedProjectRepo, GitHub, "Has its remote on / PRs opened against", $techn="", $tags="", $link="")
Rel(Forgev2.Monitor, Forgev2.EventLogArtifacts, "Tails the event log in", $techn="", $tags="", $link="")
Rel(Forgev2.Monitor, Forgev2.InitiativeQueue, "Shows queue status from", $techn="", $tags="", $link="")
Rel(Forgev2.Monitor, Forgev2.OrchestratorEngine.Scheduler, "Runs forge serve / status against", $techn="", $tags="", $link="")
Rel(Operator, Forgev2.CLIUtilities, "Runs forge serve / watch / status / metrics in", $techn="terminal", $tags="", $link="")
Rel(Operator, GitHub, "Reviews + merges the PR in", $techn="browser", $tags="", $link="")
Rel(Operator, Forgev2.Monitor, "Tails live progress via", $techn="tmux", $tags="", $link="")
Rel(Forgev2.CLIUtilities, Forgev2.OrchestratorEngine.Scheduler, "Starts the scheduler (forge serve)", $techn="", $tags="", $link="")
Rel(Forgev2.CLIUtilities, Forgev2.InitiativeQueue, "Requeue / promote manifests", $techn="", $tags="", $link="")
Rel(Forgev2.CLIUtilities, Forgev2.EventLogArtifacts, "Reads for metrics / status / recap", $techn="", $tags="", $link="")
Rel(Forgev2.CLIUtilities, Forgev2.UIBridge, "Launches", $techn="", $tags="", $link="")
Rel(Forgev2.CLIUtilities, ManagedProjectRepo, "Builds before/after worktrees + runs Playwright", $techn="", $tags="", $link="")
Rel(Forgev2.UIBridge, Forgev2.EventLogArtifacts, "Tails the event log (200ms)", $techn="", $tags="", $link="")
Rel(Forgev2.UIBridge, Forgev2.InitiativeQueue, "Scans manifests; writes verdict files", $techn="", $tags="", $link="")
Rel(Forgev2.UIBridge, Forgev2.OrchestratorEngine.ArchitectRunnerinUI, "Drives the in-UI architect runner + scheduler controls", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Scheduler, Forgev2.InitiativeQueue, "Claims + recovers manifests (atomic rename) + heartbeats", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Scheduler, Forgev2.OrchestratorEngine.WorktreeManager, "Adds a worktree per claimed initiative", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Scheduler, Forgev2.OrchestratorEngine.CycleRunnerspine, "Runs a cycle per claimed initiative", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Scheduler, Forgev2.OrchestratorEngine.SchedulerDispatch, "Routes terminal status via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Scheduler, Forgev2.OrchestratorEngine.Notifier, "Surfaces completion via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.Scheduler, Forgev2.OrchestratorEngine.DaemonControl, "Honors pause/resume + pid via", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.SchedulerDispatch, Forgev2.InitiativeQueue, "Moves the manifest (done / failed / pending)", $techn="", $tags="", $link="")
Rel(Forgev2.OrchestratorEngine.WorktreeManager, ManagedProjectRepo, "git worktree add / remove", $techn="git", $tags="", $link="")
