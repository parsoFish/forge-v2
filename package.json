{
  "name": "forge",
  "version": "2.0.0-alpha.0",
  "description": "Idea machine for one human across many side projects. Autonomous multi-agent system.",
  "type": "module",
  "private": true,
  "bin": {
    "forge": "./bin/forge.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "forge-ui"
  ],
  "scripts": {
    "build": "tsc && npm run build --workspace=forge-ui",
    "build:orchestrator": "tsc",
    "build:ui": "npm run build --workspace=forge-ui",
    "build:watch": "tsc --watch",
    "test": "node --test --experimental-strip-types orchestrator/*.test.ts orchestrator/phases/*.test.ts cli/*.test.ts loops/ralph/*.test.ts skills/*/*.test.ts scripts/*.test.ts",
    "lint": "echo 'TODO: pick a linter; v2 stays minimal until a need appears'",
    "forge": "node --experimental-strip-types orchestrator/cli.ts",
    "forge:brain:lint": "node --experimental-strip-types cli/brain-lint.ts",
    "forge:brain:index": "node --experimental-strip-types cli/brain-index.ts",
    "forge-ui:demo": "node scripts/forge-ui-demo.mjs",
    "forge-ui:harness": "node scripts/forge-ui-harness.mjs",
    "brain:scrub": "node --experimental-strip-types scripts/brain-scrub-test-contamination.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "blessed-contrib": "^4.11.0",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "pino-pretty": "^11.3.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.0"
  }
}
