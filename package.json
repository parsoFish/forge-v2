{
  "name": "forge",
  "version": "2.0.0-alpha.0",
  "description": "Idea machine for one human across many side projects. Autonomous multi-agent system.",
  "type": "module",
  "private": true,
  "bin": {
    "forge": "./bin/forge.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node --test --experimental-strip-types orchestrator/*.test.ts orchestrator/phases/*.test.ts loops/ralph/*.test.ts skills/*/*.test.ts benchmarks/_lib/*.test.ts benchmarks/*/*.test.ts scripts/*.test.ts",
    "bench:brain": "node --experimental-strip-types benchmarks/brain/score.ts",
    "bench:brain:negatives": "node --experimental-strip-types benchmarks/brain/score-negatives.ts",
    "bench:brain:judge": "node --experimental-strip-types benchmarks/brain/score-judged.ts",
    "bench:architect": "node --experimental-strip-types benchmarks/architect/score.ts",
    "bench:project-manager": "node --experimental-strip-types benchmarks/project-manager/score.ts",
    "bench:developer-loop": "node --experimental-strip-types benchmarks/developer-loop/score.ts",
    "bench:review-router": "node --experimental-strip-types benchmarks/review-router/sdk.ts",
    "bench:reflection": "node --experimental-strip-types benchmarks/reflection/score.ts",
    "bench:chained": "node --experimental-strip-types benchmarks/chained/score.ts",
    "lint": "echo 'TODO: pick a linter; v2 stays minimal until a need appears'",
    "forge": "node --experimental-strip-types orchestrator/cli.ts",
    "forge:brain:lint": "node --experimental-strip-types orchestrator/brain-lint.ts",
    "forge:brain:index": "node --experimental-strip-types orchestrator/brain-index.ts",
    "brain:scrub": "node --experimental-strip-types scripts/brain-scrub-test-contamination.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "globby": "^14.1.0",
    "gray-matter": "^4.0.3",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.6.0"
  }
}
